<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base App Theme -->
    <style name="Theme.FaceGate"
        parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">#185FA5</item>
        <item name="colorPrimaryVariant">#0C447C</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#1D9E75</item>
        <item name="colorOnSecondary">#FFFFFF</item>
        <item name="android:statusBarColor">#042C53</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
    </style>

    <!-- Dark Theme for Camera Screens -->
    <style name="Theme.FaceGate.Dark"
        parent="Theme.FaceGate">
        <item name="android:statusBarColor">#08080F</item>
        <item name="android:navigationBarColor">#08080F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Primary Button -->
    <style name="FaceGate.Button.Primary"
        parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">#185FA5</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Secondary Button -->
    <style name="FaceGate.Button.Secondary"
        parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">#D3D1C7</item>
        <item name="android:textColor">#444441</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
    </style>

    <!-- Card Style -->
    <style name="FaceGate.Card"
        parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">#FFFFFF</item>
    </style>

    <!-- Section Heading -->
    <style name="FaceGate.SectionHeading" parent="android:Widget">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#444441</item>
        <item name="android:textStyle">bold</item>
        <item name="android:layout_marginBottom">12dp</item>
    </style>

</resources>