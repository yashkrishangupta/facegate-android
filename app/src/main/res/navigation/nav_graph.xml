<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/adminDashboard">

    <!-- ========================= Dashboard ========================= -->

    <fragment
        android:id="@+id/adminDashboard"
        android:name="com.facegate.ui.admin.AdminDashboard"
        android:label="Dashboard"
        tools:layout="@layout/fragment_admin_dashboard">

        <action
            android:id="@+id/action_dashboard_to_students"
            app:destination="@id/studentsFragment" />

        <action
            android:id="@+id/action_dashboard_to_manual"
            app:destination="@id/manualAttendanceFragment" />

        <action
            android:id="@+id/action_dashboard_to_holidays"
            app:destination="@id/holidaysFragment" />

        <action
            android:id="@+id/action_dashboard_to_reports"
            app:destination="@id/attendanceReportFragment" />

        <action
            android:id="@+id/action_dashboard_to_conflicts"
            app:destination="@id/conflictQueueFragment" />

        <action
            android:id="@+id/action_dashboard_to_timetableSetup"
            app:destination="@id/timetableSetupFragment" />

        <action
            android:id="@+id/action_dashboard_to_changesLog"
            app:destination="@id/changesLogFragment" />

        <action
            android:id="@+id/action_dashboard_to_schedule"
            app:destination="@id/todayScheduleFragment" />

        <action
            android:id="@+id/action_dashboard_to_pairing"
            app:destination="@id/pairingFragment"
            app:popUpTo="@id/adminDashboard"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ========================= Device Pairing ========================= -->

    <fragment
        android:id="@+id/pairingFragment"
        android:name="com.facegate.ui.sync.PairingFragment"
        android:label="Device Setup"
        tools:layout="@layout/fragment_pairing">

        <action
            android:id="@+id/action_pairing_to_dashboard"
            app:destination="@id/adminDashboard"
            app:popUpTo="@id/adminDashboard"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ========================= Attendance ========================= -->

    <fragment
        android:id="@+id/attendanceFragment"
        android:name="com.facegate.ui.attendance.AttendanceFragment"
        android:label="Attendance"
        tools:layout="@layout/fragment_attendance">

        <argument
            android:name="sessionId"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="subject"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="batch"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="windowMinutes"
            app:argType="integer"
            android:defaultValue="10" />

        <argument
            android:name="scheduledStartTimeMs"
            app:argType="long"
            android:defaultValue="0L" />

    </fragment>

    <!-- ========================= Enrollment ========================= -->

    <fragment
        android:id="@+id/enrollmentFragment"
        android:name="com.facegate.ui.enrollment.EnrollmentFragment"
        android:label="Enroll Student"
        tools:layout="@layout/fragment_enrollment">

        <!-- Left blank for a brand-new student (dialog asks for details).
             Pre-filled when opened from the Students list for a student
             who is already synced from the website with PENDING status —
             in that case the details dialog is skipped entirely. -->
        <argument
            android:name="studentId"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="studentName"
            app:argType="string"
            android:defaultValue="" />

        <argument
            android:name="studentClass"
            app:argType="string"
            android:defaultValue="" />

        <action
            android:id="@+id/action_enrollment_to_dashboard"
            app:destination="@id/adminDashboard"
            app:popUpTo="@id/adminDashboard"
            app:popUpToInclusive="true" />

    </fragment>

    <!-- ========================= Students ========================= -->

    <fragment
        android:id="@+id/studentsFragment"
        android:name="com.facegate.ui.admin.StudentsFragment"
        android:label="Students"
        tools:layout="@layout/fragment_student">

        <action
            android:id="@+id/action_students_to_enrollment"
            app:destination="@id/enrollmentFragment" />

    </fragment>

    <!-- ========================= Manual Attendance ========================= -->

    <fragment
        android:id="@+id/manualAttendanceFragment"
        android:name="com.facegate.ui.admin.ManualAttendanceFragment"
        android:label="Manual Attendance"
        tools:layout="@layout/fragment_manual_attendance" />

    <!-- ========================= Holidays ========================= -->

    <fragment
        android:id="@+id/holidaysFragment"
        android:name="com.facegate.ui.admin.HolidaysFragment"
        android:label="Holidays"
        tools:layout="@layout/fragment_holidays" />

    <!-- ========================= Reports ========================= -->

    <fragment
        android:id="@+id/attendanceReportFragment"
        android:name="com.facegate.ui.reports.AttendanceReportFragment"
        android:label="Reports"
        tools:layout="@layout/fragment_attendance_report" />

    <!-- ========================= Conflicts ========================= -->

    <fragment
        android:id="@+id/conflictQueueFragment"
        android:name="com.facegate.ui.admin.ConflictQueueFragment"
        android:label="Conflict Queue"
        tools:layout="@layout/fragment_conflict_queue" />

    <!-- ========================= Timetable ========================= -->

    <fragment
        android:id="@+id/timetableSetupFragment"
        android:name="com.facegate.ui.admin.TimetableSetupFragment"
        android:label="Timetable"
        tools:layout="@layout/fragment_timetable_setup" />

    <!-- ========================= Changes Log ========================= -->

    <fragment
        android:id="@+id/changesLogFragment"
        android:name="com.facegate.ui.admin.ChangesLogFragment"
        android:label="Changes Log"
        tools:layout="@layout/fragment_changes_log" />


    <!-- ========================= Today's Schedule ========================= -->

    <fragment
        android:id="@+id/todayScheduleFragment"
        android:name="com.facegate.ui.schedule.TodayScheduleFragment"
        android:label="Today's Schedule"
        tools:layout="@layout/fragment_today_schedule">

        <action
            android:id="@+id/action_schedule_to_attendance"
            app:destination="@id/attendanceFragment" />

    </fragment>

</navigation>