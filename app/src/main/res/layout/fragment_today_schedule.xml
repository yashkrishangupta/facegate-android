<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- TOP BAR — dark -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:background="#0D1727"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/logo_circle"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="#5DA9FF"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:text="Today's Schedule"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date"
            android:textSize="12sp"
            android:textColor="#90A6BD"/>

    </LinearLayout>

    <!-- HOLIDAY BANNER -->
    <LinearLayout
        android:id="@+id/bannerHoliday"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2D1A0A"
        android:padding="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_dialog_alert"
            app:tint="#F59E0B"
            android:contentDescription="Holiday"/>

        <TextView
            android:id="@+id/tvHolidayMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Holiday — No Classes"
            android:textColor="#FCD34D"
            android:textSize="14sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- EMPTY STATE -->
    <TextView
        android:id="@+id/tvEmptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="No classes scheduled for today"
        android:textSize="15sp"
        android:textColor="#90A6BD"
        android:visibility="gone"/>

    <!-- PERIOD LIST -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/periodListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"/>

    </ScrollView>

    <!-- ADD UNPLANNED SESSION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#0D1727">

        <Button
            android:id="@+id/btnAddUnplanned"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/badge_blue"
            android:text="+ Add Unplanned Session"
            android:textColor="#5DA9FF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textAllCaps="false"/>

    </LinearLayout>

</LinearLayout>