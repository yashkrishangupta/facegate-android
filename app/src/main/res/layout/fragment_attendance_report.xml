<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_media_previous"
            android:tint="#444441"
            android:background="@drawable/icon_action_bg"
            android:padding="6dp"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="14dp"
            android:contentDescription="Back"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reports and Analytics"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="#1A202C"/>

    </LinearLayout>

    <!-- CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- STAT CARDS 2x2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvMonthlyPct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85.1%"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#185FA5"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="MONTHLY ATTENDANCE"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.04"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvPresentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="211"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#639922"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRESENT TODAY"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.04"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvAbsentCount"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="37"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#E24B4A"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ABSENT TODAY"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.04"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="center">
                        <TextView
                            android:id="@+id/tvTopClass"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="92.4%"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#1D9E75"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOP CLASS (10-A)"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.04"
                            android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- CLASS WISE SECTION -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Class-wise Attendance"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#444441"
                android:layout_marginBottom="12dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Class 9-A -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Class 9-A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <ProgressBar
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#639922"
                            android:progress="88"
                            android:progressBackgroundTint="#D3D1C7"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="88%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#27500A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Class 9-B -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Class 9-B"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <ProgressBar
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#639922"
                            android:progress="82"
                            android:progressBackgroundTint="#D3D1C7"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="82%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#27500A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Class 10-A -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="14dp">
                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Class 10-A"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <ProgressBar
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#639922"
                            android:progress="92"
                            android:progressBackgroundTint="#D3D1C7"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="92%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#27500A"
                            android:gravity="end"/>
                    </LinearLayout>

                    <!-- Class 10-B -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Class 10-B"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <ProgressBar
                            android:layout_width="0dp"
                            android:layout_height="7dp"
                            android:layout_weight="1"
                            android:layout_marginStart="12dp"
                            android:layout_marginEnd="12dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#639922"
                            android:progress="79"
                            android:progressBackgroundTint="#D3D1C7"/>
                        <TextView
                            android:layout_width="36dp"
                            android:layout_height="wrap_content"
                            android:text="79%"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#27500A"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- EXPORT BUTTONS -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Export Data"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#444441"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:id="@+id/btnExportExcel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp"
                android:background="@drawable/bg_export_teal"
                android:clickable="true"
                android:focusable="true"
                android:layout_marginBottom="10dp">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:tint="#0F6E56"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Export Excel"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Export Attendance to Excel (.xlsx)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#0F6E56"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/btnExportPdf"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp"
                android:background="@drawable/bg_conflict_banner"
                android:clickable="true"
                android:focusable="true">
                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_save"
                    android:tint="#A32D2D"
                    android:layout_marginEnd="10dp"
                    android:contentDescription="Export PDF"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Export Report to PDF"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#A32D2D"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</LinearLayout>