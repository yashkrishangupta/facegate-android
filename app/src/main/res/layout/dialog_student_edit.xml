<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@drawable/card_dark">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Avatar -->

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:layout_gravity="center"
            android:background="@drawable/badge_blue"
            android:padding="18dp"
            android:src="@android:drawable/ic_menu_edit"
            app:tint="#FFFFFF" />

        <!-- Title -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="18dp"
            android:text="Edit Student"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="24dp"
            android:text="Student Information"
            android:textColor="@color/text_white_60"
            android:textSize="13sp" />

        <!-- Roll Number -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Roll Number"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRollNo"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="12dp"
            android:hint="Roll number"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Registration Number -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Registration Number"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etRegistrationNumber"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_edit"
            android:drawablePadding="12dp"
            android:hint="Registration number"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Full Name -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Full Name"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etName"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_myplaces"
            android:drawablePadding="12dp"
            android:hint="Full name"
            android:imeOptions="actionNext"
            android:inputType="textPersonName|textCapWords"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Class -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Class"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etClass"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_agenda"
            android:drawablePadding="12dp"
            android:hint="Class (e.g. 10A)"
            android:imeOptions="actionNext"
            android:inputType="text"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Gender -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gender"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rgGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:orientation="horizontal">

            <RadioButton
                android:id="@+id/rbMale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:checked="true"
                android:text="Male"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/rbFemale"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Female"
                android:textColor="#FFFFFF" />

            <RadioButton
                android:id="@+id/rbOther"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Other"
                android:textColor="#FFFFFF" />

        </RadioGroup>

        <!-- Email (optional) -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email (optional)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_dialog_email"
            android:drawablePadding="12dp"
            android:hint="student@example.edu"
            android:imeOptions="actionNext"
            android:inputType="textEmailAddress"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Phone (optional) -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Phone (optional)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_call"
            android:drawablePadding="12dp"
            android:hint="10-digit mobile number"
            android:imeOptions="actionDone"
            android:inputType="phone"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Date of Birth (optional) -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Date of Birth (optional)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDateOfBirth"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/edittext_dark"
            android:clickable="true"
            android:cursorVisible="false"
            android:drawableStart="@android:drawable/ic_menu_my_calendar"
            android:drawablePadding="12dp"
            android:focusable="false"
            android:hint="Tap to select date"
            android:inputType="none"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Profile Photo URL (optional) -->

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile Photo URL (optional)"
            android:textColor="#FFFFFF"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etProfilePhotoUrl"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/edittext_dark"
            android:drawableStart="@android:drawable/ic_menu_gallery"
            android:drawablePadding="12dp"
            android:hint="https://…"
            android:imeOptions="actionDone"
            android:inputType="textUri"
            android:paddingHorizontal="18dp"
            android:textColor="#FFFFFF"
            android:textColorHint="#708090" />

        <!-- Information -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:layout_marginEnd="8dp"
                android:src="@android:drawable/ic_dialog_info"
                app:tint="@color/blue_800" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Face embedding and attendance history are unaffected by these changes."
                android:textColor="#FFFFFF"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Buttons -->

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="Cancel"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

            <Space
                android:layout_width="12dp"
                android:layout_height="1dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:background="@drawable/button_primary"
                android:text="Save"
                android:textAllCaps="false"
                android:textColor="#FFFFFF" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>