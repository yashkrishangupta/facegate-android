<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingHorizontal="20dp"
    android:paddingVertical="14dp">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="14dp"
        android:background="@drawable/chip_pending"
        android:gravity="center"
        android:textColor="#854F0B"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="JD"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Jane Doe"/>

        <TextView
            android:id="@+id/tvReason"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/text_on_surface_muted"
            android:textSize="11sp"
            tools:text="vs John Roe (0.87)"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/gray_200"
            android:textSize="11sp"
            tools:text="08:45 AM, 03 Jul"/>

    </LinearLayout>

    <TextView
        android:id="@+id/btnResolve"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:background="@drawable/icon_brand_bg"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingHorizontal="12dp"
        android:text="Resolve"
        android:textColor="#FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"/>

</LinearLayout>