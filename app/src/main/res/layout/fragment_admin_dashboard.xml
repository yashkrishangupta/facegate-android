<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F0F4F8">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="14dp"
        android:paddingBottom="14dp"
        android:background="#FFFFFF"
        android:elevation="2dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/icon_brand_bg"
                android:layout_marginEnd="12dp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_camera"
                    app:tint="#FFFFFF"
                    android:contentDescription="Brand"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="FaceGate"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A202C"/>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin Dashboard"
                    android:textSize="11sp"
                    android:textColor="#888780"/>
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#0C447C"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:background="@drawable/chip_active"/>

    </LinearLayout>

    <!-- SCROLLABLE CONTENT -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="22dp">

            <!-- Greeting Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvDate"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monday, 8 June 2026"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="#888780"
                        android:layout_marginBottom="4dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning, Admin 👋"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="#1A202C"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvClock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:42 AM"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="#185FA5"/>

            </LinearLayout>

            <!-- Conflict Banner -->
            <LinearLayout
                android:id="@+id/conflictBanner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp"
                android:background="@drawable/bg_conflict_banner"
                android:layout_marginBottom="20dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_dialog_alert"
                    app:tint="#A32D2D"
                    android:layout_marginEnd="12dp"
                    android:contentDescription="Alert"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvConflictTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="3 Open Conflicts"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:textColor="#791F1F"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Students marked both present and absent today"
                        android:textSize="11sp"
                        android:textColor="#A32D2D"
                        android:layout_marginTop="2dp"/>
                </LinearLayout>

                <Button
                    android:id="@+id/btnResolve"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Resolve"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:backgroundTint="#A32D2D"
                    android:textColor="#FFFFFF"/>

            </LinearLayout>

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Overview"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#444441"
                android:layout_marginBottom="12dp"/>

            <!-- STAT CARDS ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <!-- Total Students -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TOTAL STUDENTS"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvTotalStudents"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="248"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Enrolled this year"
                            android:textSize="11sp"
                            android:textColor="#888780"
                            android:layout_marginTop="6dp"/>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="14dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#378ADD"
                            android:progress="100"
                            android:progressBackgroundTint="#D3D1C7"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Present Today -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRESENT TODAY"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvPresentToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="211"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="85.1% attendance rate"
                            android:textSize="11sp"
                            android:textColor="#888780"
                            android:layout_marginTop="6dp"/>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="14dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#639922"
                            android:progress="85"
                            android:progressBackgroundTint="#D3D1C7"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- STAT CARDS ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Absent Today -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ABSENT TODAY"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvAbsentToday"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="37"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="14.9% absent today"
                            android:textSize="11sp"
                            android:textColor="#888780"
                            android:layout_marginTop="6dp"/>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="14dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#E24B4A"
                            android:progress="15"
                            android:progressBackgroundTint="#D3D1C7"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Holidays Left -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp"
                    app:cardBackgroundColor="#FFFFFF">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="18dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HOLIDAYS LEFT"
                            android:textSize="10sp"
                            android:textStyle="bold"
                            android:textColor="#888780"
                            android:letterSpacing="0.06"
                            android:layout_marginBottom="8dp"/>
                        <TextView
                            android:id="@+id/tvHolidaysLeft"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textSize="30sp"
                            android:textStyle="bold"
                            android:textColor="#1A202C"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Remaining this semester"
                            android:textSize="11sp"
                            android:textColor="#888780"
                            android:layout_marginTop="6dp"/>
                        <ProgressBar
                            android:layout_width="match_parent"
                            android:layout_height="3dp"
                            android:layout_marginTop="14dp"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:progressTint="#BA7517"
                            android:progress="40"
                            android:progressBackgroundTint="#D3D1C7"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- QUICK ACTIONS TITLE -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#444441"
                android:layout_marginBottom="12dp"/>

            <!-- QUICK ACTION TILES ROW 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/tileStudents"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_tile_blue"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_manage"
                                app:tint="#185FA5"
                                android:contentDescription="Students"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manage Students"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1A202C"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add, edit, remove"
                                android:textSize="11sp"
                                android:textColor="#888780"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tileManual"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_tile_green"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_edit"
                                app:tint="#3B6D11"
                                android:contentDescription="Manual"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manual Attendance"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1A202C"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Mark individually"
                                android:textSize="11sp"
                                android:textColor="#888780"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

            <!-- QUICK ACTION TILES ROW 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <androidx.cardview.widget.CardView
                    android:id="@+id/tileHolidays"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_tile_amber"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_today"
                                app:tint="#854F0B"
                                android:contentDescription="Holidays"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Holidays"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1A202C"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Manage calendar"
                                android:textSize="11sp"
                                android:textColor="#888780"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/tileReports"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="6dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:foreground="?attr/selectableItemBackground"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="1dp">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:padding="18dp">
                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/icon_tile_teal"
                            android:layout_marginEnd="14dp">
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center"
                                android:src="@android:drawable/ic_menu_sort_by_size"
                                app:tint="#0F6E56"
                                android:contentDescription="Reports"/>
                        </FrameLayout>
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Reports"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#1A202C"/>
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Analytics and export"
                                android:textSize="11sp"
                                android:textColor="#888780"
                                android:layout_marginTop="3dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- BOTTOM NAVIGATION -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/navHome"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@drawable/chip_active"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_today"
                app:tint="#185FA5"
                android:contentDescription="Home"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Home"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#185FA5"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navStudents"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_manage"
                app:tint="#888780"
                android:contentDescription="Students"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Students"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#888780"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navAttendance"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_edit"
                app:tint="#888780"
                android:contentDescription="Attendance"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Attendance"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#888780"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navReports"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_sort_by_size"
                app:tint="#888780"
                android:contentDescription="Reports"/>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reports"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#888780"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/navExit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
