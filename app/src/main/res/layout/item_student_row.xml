<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="@color/surface_card"
    android:paddingHorizontal="14dp"
    android:paddingVertical="10dp">

    <TextView
        android:id="@+id/tvAvatar"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_marginEnd="12dp"
        android:background="@drawable/chip_active"
        android:gravity="center"
        android:textColor="#1D9E75"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="JD"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_on_surface"
            android:textSize="14sp"
            android:textStyle="bold"
            tools:text="Jane Doe"/>

        <TextView
            android:id="@+id/tvSubInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#000000"
            android:textSize="11sp"
            tools:text="STU-0042  •  Class 10A"/>

    </LinearLayout>

    <TextView
        android:id="@+id/btnEdit"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:layout_marginEnd="4dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="✎"
        android:textColor="#037A09"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/btnDelete"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:text="✕"
        android:textColor="#E4080E"
        android:textSize="14sp"/>

</LinearLayout>