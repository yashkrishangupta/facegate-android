<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@drawable/bg_main_gradient"
    tools:context=".ui.sync.PairingFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Device Setup"
            android:textColor="@color/text_white"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:text="Ask an admin to create this device on the website — they'll give you a 6-digit pairing code. Enter it below."
            android:textColor="@color/text_white_60"
            android:textSize="13sp"/>

        <EditText
            android:id="@+id/etPairingCode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:hint="6-digit pairing code"
            android:inputType="number"
            android:maxLength="6"
            android:maxLines="1"
            android:gravity="center"
            android:letterSpacing="0.3"
            android:textSize="20sp"
            android:padding="14dp"
            android:background="@drawable/badge_blue"
            android:backgroundTint="@color/surface_card"
            android:textColor="@color/text_on_surface"
            android:textColorHint="#9AA3AF"/>

        <TextView
            android:id="@+id/tvFeedback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:textColor="@color/red_600"
            android:textSize="12sp"
            android:visibility="gone"
            tools:text="Pairing failed: invalid token"
            tools:visibility="visible"/>

        <TextView
            android:id="@+id/btnPair"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/badge_blue"
            android:backgroundTint="@color/blue_600"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingVertical="14dp"
            android:text="Pair Device"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"/>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            tools:visibility="visible"/>

    </LinearLayout>

</ScrollView>