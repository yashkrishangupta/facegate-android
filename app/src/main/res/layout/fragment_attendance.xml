<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#08080F">

    <!-- TOP BAR -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:gravity="center"
            android:background="@drawable/btn_camera_back"
            android:clickable="true"
            android:focusable="true"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <TextView
            android:id="@+id/tvScanBadge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Searching…"
            android:textColor="#B5D4F4"
            android:textSize="12sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="7dp"
            android:paddingBottom="7dp"
            android:background="@drawable/badge_blue"/>

    </LinearLayout>

    <!-- CAMERA VIEWPORT -->
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="16dp"
        android:background="@drawable/bg_camera"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintBottom_toTopOf="@id/instructionLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- CameraX Preview -->
        <androidx.camera.view.PreviewView
            android:id="@+id/cameraPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <!-- Face Oval -->
        <ImageView
            android:id="@+id/faceOval"
            android:layout_width="300dp"
            android:layout_height="400dp"
            android:layout_gravity="center"
            android:contentDescription="Face guide oval"
            android:src="@drawable/oval_face_guide" />

        <!-- Scan Line -->
        <View
            android:id="@+id/scanLine"
            android:layout_width="280dp"
            android:layout_height="2dp"
            android:layout_gravity="center"
            android:background="@drawable/scan_line_gradient"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- INSTRUCTIONS -->
    <LinearLayout
        android:id="@+id/instructionLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="12dp"
        app:layout_constraintBottom_toTopOf="@id/controlsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="READY"
            android:textColor="#B5D4F4"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvStatusMain"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Place your face inside the oval"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tvStatusSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keep your face centered and look straight"
            android:textColor="#6BFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:layout_marginTop="6dp"/>

        <!-- Processing Dots -->
        <LinearLayout
            android:id="@+id/processingDots"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="10dp"
            android:visibility="gone">

            <View
                android:id="@+id/dot1"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/circle_deco_blue"/>
            <View
                android:id="@+id/dot2"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/circle_deco_blue"/>
            <View
                android:id="@+id/dot3"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/circle_deco_blue"/>
        </LinearLayout>

    </LinearLayout>

    <!-- BOTTOM CONTROLS -->
    <LinearLayout
        android:id="@+id/controlsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:paddingBottom="24dp"
        android:paddingTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/btnRetry"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="↺  Retry"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/btn_camera_back"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="20dp"
            android:visibility="invisible"/>

        <FrameLayout
            android:id="@+id/btnShutter"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:background="@drawable/shutter_button_bg"
            android:clickable="true"
            android:focusable="true">
            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_camera"
                android:contentDescription="Capture"/>
        </FrameLayout>

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="✕  Cancel"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:background="@drawable/btn_camera_back"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginStart="20dp"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>