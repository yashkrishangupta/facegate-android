<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- TOP BAR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp"
        android:background="@color/surface_topbar"
        android:elevation="6dp">

        <TextView
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="← Back"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:paddingHorizontal="14dp"
            android:gravity="center"
            android:background="@drawable/badge_blue"
            android:clickable="true"
            android:focusable="true"
            android:layout_marginEnd="14dp"/>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Timetable Setup"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_on_surface"/>

    </LinearLayout>

    <!-- DAY TABS -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#0D1727"
        android:scrollbars="none">
        <LinearLayout
            android:id="@+id/dayTabRow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"/>
    </HorizontalScrollView>

    <!-- WEEKLY OFF TOGGLE -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#111C30"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp">

        <TextView
            android:id="@+id/tvWeeklyOffLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Weekly Off"
            android:textColor="#90A6BD"
            android:textSize="13sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/btnWeeklyOffToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/button_outline"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Mark as Weekly Off"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:textStyle="bold"/>

    </LinearLayout>

    <!-- WEEKLY OFF BANNER -->
    <TextView
        android:id="@+id/tvWeeklyOffBanner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#2D1A0A"
        android:gravity="center"
        android:padding="14dp"
        android:text="This day is marked as Weekly Off — no periods will be scheduled."
        android:textColor="#FCD34D"
        android:textSize="13sp"
        android:textStyle="bold"
        android:visibility="gone"/>

    <!-- PERIOD LIST -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/periodListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/emptyState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:gravity="center"
                android:text="No periods for this day — tap + Add Period to add"
                android:textColor="#90A6BD"
                android:textSize="14sp"
                android:visibility="gone"/>

        </LinearLayout>
    </ScrollView>

    <!-- ADD PERIOD -->
    <TextView
        android:id="@+id/btnAddPeriod"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/accent_blue_strong"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:paddingVertical="16dp"
        android:text="+ Add Period"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"/>

</LinearLayout>